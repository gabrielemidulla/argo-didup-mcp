# Argo (MCP + CLI): credenziali portale famiglia
CODICE_SCUOLA=
USERNAME=
PASSWORD=

# MCP HTTP (bun run serve da packages/argo-mcp). Locale: senza token → 127.0.0.1; con token → 0.0.0.0 + Bearer.
# In Docker Compose, MCP_HOST=0.0.0.0: se AUTH_TOKEN è vuoto e la porta è esposta, il servizio è senza auth.
AUTH_TOKEN=
# MCP_HOST=
PORT=3000

# Idle Bun (0 = off, consigliato per MCP/SSE)
MCP_IDLE_TIMEOUT=0

# PUPPETEER_EXECUTABLE_PATH=/usr/bin/chromium

TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
# Default locale: packages/telegram-bot/MEMORY.md. Compose: volume su /data/MEMORY.md.
# TELEGRAM_MEMORY_PATH=
GOOGLE_API_KEY=

# MySQL (automation_*). In locale opzionale; in Compose allineare password a docker-compose.yml se usi .env.
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_DATABASE=argo_bot
MYSQL_USER=argo
MYSQL_PASSWORD=
MYSQL_ROOT_PASSWORD=
