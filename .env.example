# Argo (MCP + CLI): credenziali portale famiglia
CODICE_SCUOLA=
USERNAME=
PASSWORD=

# Server HTTP MCP (dalla root: bun run serve — vedi packages/argo-mcp)
# AUTH_TOKEN vuoto = solo localhost (127.0.0.1), nessun header Bearer richiesto.
# Con token non vuoto = ascolto su 0.0.0.0 e Bearer obbligatorio.
AUTH_TOKEN=
# Opzionale: sovrascrive l'host di bind (es. MCP_HOST=0.0.0.0 in Docker senza token — sconsigliato)
# MCP_HOST=
PORT=3000

# Secondi di idle su Bun prima di chiudere la connessione (0 = disabilitato, consigliato per MCP/SSE)
MCP_IDLE_TIMEOUT=0

# Opzionale: Chromium di sistema (es. Docker)
# PUPPETEER_EXECUTABLE_PATH=/usr/bin/chromium

# Bot Telegram (dalla root: bun run telegram — vedi packages/telegram-bot). Solo questo chat ID viene servito
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
# Opzionale: file Markdown memoria persistente (preferenze). Default: packages/telegram-bot/MEMORY.md (gitignored)
# TELEGRAM_MEMORY_PATH=
# Google AI Studio / Gemini
GOOGLE_API_KEY=

# MySQL: automazioni pianificate (cron + prompt). Opzionale in locale: senza queste variabili il bot funziona ma senza automation_* tools.
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_DATABASE=argo_bot
MYSQL_USER=argo
MYSQL_PASSWORD=
# Solo Docker Compose (servizio mysql)
MYSQL_ROOT_PASSWORD=
