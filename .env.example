# Argo (MCP + CLI): credenziali portale famiglia
CODICE_SCUOLA=
USERNAME=
PASSWORD=

# Server HTTP MCP (bun index.ts serve)
# AUTH_TOKEN vuoto = solo localhost (127.0.0.1), nessun header Bearer richiesto.
# Con token non vuoto = ascolto su 0.0.0.0 e Bearer obbligatorio.
AUTH_TOKEN=
# Opzionale: sovrascrive l'host di bind (es. MCP_HOST=0.0.0.0 in Docker senza token — sconsigliato)
# MCP_HOST=
PORT=3000

# Secondi di idle su Bun prima di chiudere la connessione (0 = disabilitato, consigliato per MCP/SSE)
MCP_IDLE_TIMEOUT=0

# Opzionale: Chromium di sistema (es. Docker)
# PUPPETEER_EXECUTABLE_PATH=/usr/bin/chromium

# Bot Telegram (bun index.ts telegram) — solo questo chat ID viene servito
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
# Google AI Studio / Gemini
GOOGLE_API_KEY=
